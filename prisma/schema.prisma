generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  super_admin
  admin
  tenaga_pengajar
  ahli
}

enum AssignmentType {
  file_upload
  text
}

enum QuestionType {
  multiple_choice
  true_false
  short_answer
}

enum AttemptStatus {
  in_progress
  submitted
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

// ─── Models ─────────────────────────────────────────────

model Ipt {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  slug       String   @unique
  logo_url   String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz()

  users              User[]
  courses            Course[]
  course_weeks       CourseWeek[]
  enrollments        Enrollment[]
  assignments        Assignment[]
  submissions        Submission[]
  quizzes            Quiz[]
  quiz_questions     QuizQuestion[]
  quiz_attempts      QuizAttempt[]
  attendance_sessions AttendanceSession[]
  attendance_records AttendanceRecord[]
  schedules          Schedule[]

  @@map("ipts")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  ipt_id         String   @db.Uuid
  ic_number      String
  nama           String
  role           Role
  kelas_latihan  String?
  password_hash  String
  created_at     DateTime @default(now()) @db.Timestamptz()

  ipt                    Ipt                @relation(fields: [ipt_id], references: [id], onDelete: Cascade)
  created_courses        Course[]           @relation("CourseCreator")
  enrollments            Enrollment[]
  created_assignments    Assignment[]       @relation("AssignmentCreator")
  submissions            Submission[]       @relation("SubmissionAuthor")
  graded_submissions     Submission[]       @relation("SubmissionGrader")
  created_quizzes        Quiz[]             @relation("QuizCreator")
  quiz_attempts          QuizAttempt[]
  created_att_sessions   AttendanceSession[] @relation("AttSessionCreator")
  attendance_records     AttendanceRecord[]
  created_schedules      Schedule[]         @relation("ScheduleCreator")

  @@unique([ipt_id, ic_number])
  @@map("users")
}

model Course {
  id          String   @id @default(uuid()) @db.Uuid
  ipt_id      String   @db.Uuid
  title       String
  description String?
  created_by  String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz()

  ipt                 Ipt                @relation(fields: [ipt_id], references: [id], onDelete: Cascade)
  creator             User               @relation("CourseCreator", fields: [created_by], references: [id])
  weeks               CourseWeek[]
  enrollments         Enrollment[]
  assignments         Assignment[]
  quizzes             Quiz[]
  attendance_sessions AttendanceSession[]
  schedules           Schedule[]

  @@map("courses")
}

model CourseWeek {
  id          String   @id @default(uuid()) @db.Uuid
  course_id   String   @db.Uuid
  ipt_id      String   @db.Uuid
  week_number Int
  title       String
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz()

  course      Course       @relation(fields: [course_id], references: [id], onDelete: Cascade)
  ipt         Ipt          @relation(fields: [ipt_id], references: [id], onDelete: Cascade)
  assignments Assignment[]
  quizzes     Quiz[]

  @@unique([course_id, week_number])
  @@map("course_weeks")
}

model Enrollment {
  id          String   @id @default(uuid()) @db.Uuid
  course_id   String   @db.Uuid
  user_id     String   @db.Uuid
  ipt_id      String   @db.Uuid
  enrolled_at DateTime @default(now()) @db.Timestamptz()

  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ipt    Ipt    @relation(fields: [ipt_id], references: [id], onDelete: Cascade)

  @@unique([course_id, user_id])
  @@map("enrollments")
}

model Assignment {
  id          String         @id @default(uuid()) @db.Uuid
  course_id   String         @db.Uuid
  week_id     String         @db.Uuid
  ipt_id      String         @db.Uuid
  title       String
  description String?
  type        AssignmentType
  due_date    DateTime?      @db.Timestamptz()
  max_score   Int            @default(100)
  created_by  String         @db.Uuid
  created_at  DateTime       @default(now()) @db.Timestamptz()

  course      Course       @relation(fields: [course_id], references: [id], onDelete: Cascade)
  week        CourseWeek   @relation(fields: [week_id], references: [id], onDelete: Cascade)
  ipt         Ipt          @relation(fields: [ipt_id], references: [id], onDelete: Cascade)
  creator     User         @relation("AssignmentCreator", fields: [created_by], references: [id])
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id            String    @id @default(uuid()) @db.Uuid
  assignment_id String    @db.Uuid
  user_id       String    @db.Uuid
  ipt_id        String    @db.Uuid
  content_text  String?
  file_path     String?
  submitted_at  DateTime  @default(now()) @db.Timestamptz()
  grade         Decimal?  @db.Decimal
  feedback      String?
  graded_by     String?   @db.Uuid
  graded_at     DateTime? @db.Timestamptz()

  assignment Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  user       User       @relation("SubmissionAuthor", fields: [user_id], references: [id], onDelete: Cascade)
  ipt        Ipt        @relation(fields: [ipt_id], references: [id], onDelete: Cascade)
  grader     User?      @relation("SubmissionGrader", fields: [graded_by], references: [id])

  @@unique([assignment_id, user_id])
  @@map("submissions")
}

model Quiz {
  id                  String   @id @default(uuid()) @db.Uuid
  course_id           String   @db.Uuid
  week_id             String   @db.Uuid
  ipt_id              String   @db.Uuid
  title               String
  description         String?
  timer_minutes       Int?
  randomize_questions Boolean  @default(false)
  created_by          String   @db.Uuid
  created_at          DateTime @default(now()) @db.Timestamptz()

  course    Course         @relation(fields: [course_id], references: [id], onDelete: Cascade)
  week      CourseWeek     @relation(fields: [week_id], references: [id], onDelete: Cascade)
  ipt       Ipt            @relation(fields: [ipt_id], references: [id], onDelete: Cascade)
  creator   User           @relation("QuizCreator", fields: [created_by], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id             String       @id @default(uuid()) @db.Uuid
  quiz_id        String       @db.Uuid
  ipt_id         String       @db.Uuid
  question_text  String
  question_type  QuestionType
  options        Json?
  correct_answer String?
  marks          Int          @default(1)
  order_index    Int

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  ipt  Ipt  @relation(fields: [ipt_id], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id           String        @id @default(uuid()) @db.Uuid
  quiz_id      String        @db.Uuid
  user_id      String        @db.Uuid
  ipt_id       String        @db.Uuid
  started_at   DateTime      @default(now()) @db.Timestamptz()
  submitted_at DateTime?     @db.Timestamptz()
  answers      Json?
  score        Decimal?      @db.Decimal
  status       AttemptStatus @default(in_progress)

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ipt  Ipt  @relation(fields: [ipt_id], references: [id], onDelete: Cascade)

  @@unique([quiz_id, user_id])
  @@map("quiz_attempts")
}

model AttendanceSession {
  id           String   @id @default(uuid()) @db.Uuid
  course_id    String   @db.Uuid
  ipt_id       String   @db.Uuid
  session_date DateTime @db.Date
  title        String
  created_by   String   @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz()

  course  Course             @relation(fields: [course_id], references: [id], onDelete: Cascade)
  ipt     Ipt                @relation(fields: [ipt_id], references: [id], onDelete: Cascade)
  creator User               @relation("AttSessionCreator", fields: [created_by], references: [id])
  records AttendanceRecord[]

  @@map("attendance_sessions")
}

model AttendanceRecord {
  id         String           @id @default(uuid()) @db.Uuid
  session_id String           @db.Uuid
  user_id    String           @db.Uuid
  ipt_id     String           @db.Uuid
  status     AttendanceStatus
  remark     String?
  marked_at  DateTime         @default(now()) @db.Timestamptz()

  session AttendanceSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ipt     Ipt               @relation(fields: [ipt_id], references: [id], onDelete: Cascade)

  @@unique([session_id, user_id])
  @@map("attendance_records")
}

model Schedule {
  id         String   @id @default(uuid()) @db.Uuid
  course_id  String   @db.Uuid
  ipt_id     String   @db.Uuid
  title      String
  start_time DateTime @db.Timestamptz()
  end_time   DateTime @db.Timestamptz()
  location   String?
  recurring  Boolean  @default(false)
  created_by String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz()

  course  Course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  ipt     Ipt    @relation(fields: [ipt_id], references: [id], onDelete: Cascade)
  creator User   @relation("ScheduleCreator", fields: [created_by], references: [id])

  @@map("schedules")
}
